{
  "context_servers": {
    "better-t-stack": {
      "source": "custom",
      "command": "bunx",
      "args": ["create-better-t-stack@latest", "mcp"],
      "env": {}
    },
    "context7": {
      "source": "custom",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "convex": {
      "source": "custom",
      "command": "npx",
      "args": ["-y", "convex@latest", "mcp", "start"],
      "env": {}
    },
    "clerk": {
      "source": "custom",
      "type": "http",
      "url": "https://mcp.clerk.com/mcp",
      "headers": {}
    },
    "expo-mcp": {
      "source": "custom",
      "type": "http",
      "url": "https://mcp.expo.dev/mcp",
      "headers": {}
    }
  }
}
